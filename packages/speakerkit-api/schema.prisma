// This file is automatically generated by Keystone, do not modify it manually.
// Modify your Keystone config when you want to change this.

datasource postgresql {
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
  provider          = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = ".keystone/speakerkit-prisma-client"
}

model Speaker {
  id          String       @id @default(cuid())
  name        String       @default("")
  bio         String       @default("")
  avatarUrl   String       @default("")
  linkedinUrl String       @default("")
  siteUrl     String       @default("")
  interviews  Interview[]  @relation("Interview_speakers")
  clips       Clip[]       @relation("Clip_speaker")
  quotes      Quote[]      @relation("Quote_speaker")
  blogPosts   BlogPost[]   @relation("BlogPost_speaker")
  socialPosts SocialPost[] @relation("SocialPost_speaker")
  createdAt   DateTime?    @default(now())
  updatedAt   DateTime?    @updatedAt
}

model Interview {
  id                 String       @id @default(cuid())
  title              String       @default("")
  description        String       @default("")
  speakers           Speaker[]    @relation("Interview_speakers")
  originalVideoUrl   String       @default("")
  duration           Int?
  recordedAt         DateTime?
  sourceId           String       @default("")
  sourceTranscriptId String       @default("")
  clips              Clip[]       @relation("Clip_interview")
  quotes             Quote[]      @relation("Quote_interview")
  blogPosts          BlogPost[]   @relation("BlogPost_interview")
  socialPosts        SocialPost[] @relation("SocialPost_interview")
  createdAt          DateTime?    @default(now())
  updatedAt          DateTime?    @updatedAt
}

model Clip {
  id                    String            @id @default(cuid())
  title                 String            @default("")
  description           String            @default("")
  interview             Interview?        @relation("Clip_interview", fields: [interviewId], references: [id])
  interviewId           String?           @map("interview")
  speaker               Speaker?          @relation("Clip_speaker", fields: [speakerId], references: [id])
  speakerId             String?           @map("speaker")
  startTime             Int?
  endTime               Int?
  videoUrl              String            @default("")
  platform              ClipPlatformType? @default(linkedin)
  sortOrder             Int?              @default(0)
  reachScore            Decimal?          @postgresql.Decimal(18, 4)
  reachReasoning        String            @default("")
  provocationScore      Decimal?          @postgresql.Decimal(18, 4)
  provocationReasoning  String            @default("")
  valueScore            Decimal?          @postgresql.Decimal(18, 4)
  valueReasoning        String            @default("")
  storytellingScore     Decimal?          @postgresql.Decimal(18, 4)
  storytellingReasoning String            @default("")
  createdAt             DateTime?         @default(now())
  updatedAt             DateTime?         @updatedAt

  @@index([interviewId])
  @@index([speakerId])
}

model Quote {
  id               String     @id @default(cuid())
  text             String     @default("")
  attribution      String     @default("")
  interview        Interview? @relation("Quote_interview", fields: [interviewId], references: [id])
  interviewId      String?    @map("interview")
  speaker          Speaker?   @relation("Quote_speaker", fields: [speakerId], references: [id])
  speakerId        String?    @map("speaker")
  timestampInVideo Int?
  sortOrder        Int?       @default(0)
  createdAt        DateTime?  @default(now())
  updatedAt        DateTime?  @updatedAt

  @@index([interviewId])
  @@index([speakerId])
}

model BlogPost {
  id               String     @id @default(cuid())
  title            String     @default("")
  imageUrl         String     @default("")
  shortDescription String     @default("")
  content          String     @default("")
  interview        Interview? @relation("BlogPost_interview", fields: [interviewId], references: [id])
  interviewId      String?    @map("interview")
  speaker          Speaker?   @relation("BlogPost_speaker", fields: [speakerId], references: [id])
  speakerId        String?    @map("speaker")
  sortOrder        Int?       @default(0)
  createdAt        DateTime?  @default(now())
  updatedAt        DateTime?  @updatedAt

  @@index([interviewId])
  @@index([speakerId])
}

model SocialPost {
  id          String                  @id @default(cuid())
  platform    SocialPostPlatformType? @default(linkedin)
  content     String                  @default("")
  imageUrl    String                  @default("")
  interview   Interview?              @relation("SocialPost_interview", fields: [interviewId], references: [id])
  interviewId String?                 @map("interview")
  speaker     Speaker?                @relation("SocialPost_speaker", fields: [speakerId], references: [id])
  speakerId   String?                 @map("speaker")
  sortOrder   Int?                    @default(0)
  createdAt   DateTime?               @default(now())
  updatedAt   DateTime?               @updatedAt

  @@index([interviewId])
  @@index([speakerId])
}

enum ClipPlatformType {
  linkedin
  youtube_shorts
  instagram_reels
  tiktok
}

enum SocialPostPlatformType {
  linkedin
  twitter
  facebook
  instagram
}
